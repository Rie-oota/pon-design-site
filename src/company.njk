  <section id="company-info" class="p-company-info">
    <div class="container l-container p-company-info__container">
      <h2 class="c-section-title c-title">
        <span class="c-section-title__main">会社情報</span>
      </h2>
      <dl class="p-company-info__list">
        <div class="p-company-info__row">
